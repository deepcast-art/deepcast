# Copy to ".env" in the project root and fill in real values. Never commit ".env".
# Production: set the same variable names in your host (e.g. Render → Environment). Do not upload a .env file.

# Supabase (API server — use service role for server/index.js)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Resend — https://resend.com (domain must be verified in Resend dashboard)
RESEND_API_KEY=re_xxxxxxxx
# Must use YOUR verified domain (not a placeholder like yourdomain.com)
RESEND_FROM_EMAIL=Deepcast <invites@deepcast.art>

# Mux — https://dashboard.mux.com
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=

# Public URL of your app (invite links). Local dev matches Vite default port (see vite.config.js server.port).
APP_URL=http://localhost:3000

# Optional: reject screening invites after expires_at (410). Default is off so links do not die by date.
# Set both this and INVITE_EXPIRY_DAYS if you want time-limited invites (e.g. tests or strict rollout).
# INVITE_ENFORCE_EXPIRY=true

# When INVITE_ENFORCE_EXPIRY is true, skip the expiry check (local dev / emergency).
# SKIP_INVITE_EXPIRY_CHECK=true

# Screening invite lifetime in days for newly created invites (default 365). Stored on the row for analytics / future enforcement.
# INVITE_EXPIRY_DAYS=365

# Client-only: password reset email link must land here (add the same URL in Supabase → Auth → URL Configuration → Redirect URLs)
# VITE_APP_URL=http://localhost:5173
# Or set the full path explicitly:
# VITE_PASSWORD_RESET_REDIRECT_URL=http://localhost:5173/reset-password

# Invite screening pause / thank-you diptych — optional partner line between columns (default: Brain Farm).
# VITE_SCREENING_ASSOCIATION_NAME=Brain Farm

# Landing — optional full-viewport background image (object-fit: cover, centered). Omit for solid theme bg.
# VITE_LANDING_HERO_BG_URL=/your-hero.jpg

# Invite URL context encryption — AES-256 key (64 hex chars = 32 bytes).
# Generate once: node -e "const c=require('crypto');console.log(c.randomBytes(32).toString('hex'))"
# Must be the same value on server (INVITE_CTX_SECRET) and client (VITE_INVITE_CTX_SECRET).
INVITE_CTX_SECRET=your_64_hex_char_key_here
VITE_INVITE_CTX_SECRET=your_64_hex_char_key_here

# Landing intro (defaults to shared Mux explainer — see src/lib/introFilm.js)
# Optional: override Mux playback ID for the ~120s intro on home + invite intro stage
# VITE_LANDING_INTRO_PLAYBACK_ID=
# Optional: use a film row’s mux_playback_id when status is ready (takes precedence over default ID)
# VITE_LANDING_INTRO_FILM_ID=
# Optional: use a plain MP4/WebM URL instead of Mux (overrides everything above)
# VITE_LANDING_INTRO_VIDEO_URL=https://example.com/deepcast-intro.mp4
