# Copy to ".env" in the project root and fill in real values. Never commit ".env".

# Supabase (API server — use service role for server/index.js)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Resend — https://resend.com (domain must be verified in Resend dashboard)
RESEND_API_KEY=re_xxxxxxxx
# Must use YOUR verified domain (not a placeholder like yourdomain.com)
RESEND_FROM_EMAIL=Deepcast <invites@deepcast.art>

# Mux — https://dashboard.mux.com
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=

# Public URL of your app (invite links). Local dev can stay default or use http://localhost:5173
APP_URL=http://localhost:5173
